# ============================================================
# FTP Echo — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub
# ============================================================

# Server
PORT=3001
NODE_ENV=production

# Frontend URL (your Vercel domain)
FRONTEND_URL=https://ftpecho.com

# Supabase — get these from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# GitHub OAuth — create an OAuth app at github.com/settings/developers
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=https://your-server.com/github/callback

# Encryption key for storing FTP credentials (32 random characters)
ENCRYPTION_KEY=your-32-character-random-string-here

# Session secret
SESSION_SECRET=another-long-random-string-here
